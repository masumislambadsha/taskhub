{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "reactbits": {
      "type": "local",
      "command": ["npx", "-y", "reactbits-dev-mcp-server"],
      "enabled": true
    },
    "mongodb": {
      "type": "local",
      "command": ["npx", "-y", "mongodb-mcp-server@latest", "--readOnly"],
      "enabled": true,
      "environment": {
        "MDB_MCP_CONNECTION_STRING": "{env:MONGODB_URI}"
      }
    },
    "expo": {
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "enabled": true,
      "oauth": {}
    }
  }
}
